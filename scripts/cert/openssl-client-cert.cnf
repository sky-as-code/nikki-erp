[ ca ]
default_ca = client_ca

[ client_ca ]
dir               = $ENV::CWD/pki
database          = $dir/client-ca/index.txt
serial            = $dir/client-ca/serial.txt
new_certs_dir     = $dir/client-ca/signed-certs
certificate       = $dir/client-ca/$ENV::CA_CN.crt
private_key       = $dir/client-ca/$ENV::CA_CN.key
copy_extensions = copy
default_md        = sha256
policy            = policy_any

[ policy_any ]
commonName        = supplied

[ req ]
default_bits        = 4096
prompt              = no
default_md          = sha256
distinguished_name  = dn
req_extensions      = v3_server

[ v3_client ]
basicConstraints = CA:FALSE
keyUsage = digitalSignature
extendedKeyUsage = clientAuth

[ dn ]
O  = $ENV::O
OU = $ENV::OU
CN = $ENV::CN
