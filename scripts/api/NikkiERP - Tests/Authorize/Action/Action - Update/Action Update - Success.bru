meta {
  name: Action Update - Success
  type: http
  seq: 1
}

patch {
  url: {{api_host}}/v1/authorize/resources/{{resource_id}}/actions/{{action_id}}
  body: json
  auth: inherit
}

body:json {
  {
    "name": "{{$randomVerb}}   {{$timestamp}}",
    "description": "{{$randomLoremParagraphs}}",
    "etag": "{{etag}}"
  }
}

script:pre-request {
  const body = req.getBody();
  
  if (body.hasOwnProperty('code')) {
    body.name = bru.interpolate(body.name);
    body.code = body.name.toLowerCase().replace(/\s+/g, "_");
    req.setBody(body);
  }
}

script:post-response {
  const pkg = require('./scripts/update-success');
  
  pkg.testUpdate(1);
  
}

settings {
  encodeUrl: true
  timeout: 0
}
