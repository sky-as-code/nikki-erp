meta {
  name: Action Update - Unmatched etag - Validation errors
  type: http
  seq: 4
}

put {
  url: {{api_host}}/v1/authorize/resources/{{resource_id}}/actions/{{action_id}}
  body: json
  auth: inherit
}

body:json {
  {
    "name": "{{$randomCatchPhraseAdjective}}",
    "etag": "___________________"
  }
}

script:post-response {
  const pkg = require('./scripts/error-400-etag-unmatched');
  
  pkg.testUnmatchedEtag();
  
}

settings {
  encodeUrl: true
  timeout: 0
}
