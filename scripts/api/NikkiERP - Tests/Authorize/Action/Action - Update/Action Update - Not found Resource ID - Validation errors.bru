meta {
  name: Action Update - Not found Resource ID - Validation errors
  type: http
  seq: 3
}

put {
  url: {{api_host}}/v1/authorize/resources/01KMMJYC5G8K5PHEAV3VZQQ63F/actions/{{action_id}}
  body: json
  auth: inherit
}

body:json {
  {
      "etag": "{{etag}}"
  }
}

script:post-response {
  const pkg = require('./scripts/error-400-not-found');
  
  pkg.testFieldNotFound('resource_id');
  
}

settings {
  encodeUrl: true
  timeout: 0
}
