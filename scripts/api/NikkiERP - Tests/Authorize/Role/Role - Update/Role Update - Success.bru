meta {
  name: Role Update - Success
  type: http
  seq: 1
}

put {
  url: {{api_host}}/v1/authorize/roles/{{role_id}}
  body: json
  auth: inherit
}

body:json {
  {
    "name": "{{$randomJobArea}} {{$randomCatchPhraseAdjective}} Role Updated",
    "description": "{{$randomLoremParagraphs}}",
    "etag": "{{etag}}"
  }
}

script:post-response {
  const pkg = require('./scripts/update-success');
  
  pkg.testUpdate(1);
  
}

settings {
  encodeUrl: true
  timeout: 0
}
