meta {
  name: Role Create - Required fields - Success
  type: http
  seq: 1
}

post {
  url: {{api_host}}/v1/authorize/roles
  body: json
  auth: inherit
}

body:json {
  {
    "name": "{{$randomJobArea}} {{$randomCatchPhraseAdjective}} Role",
    "is_requestable": false,
    "is_required_attachment": false,
    "is_required_comment": false
  }
}

script:post-response {
  const pkg = require('./scripts/create-success');
  
  pkg.testCreate('role_id');
  
}

settings {
  encodeUrl: true
  timeout: 0
}
