meta {
  name: Resource Create - Empty strings - Validation errors
  type: http
  seq: 3
}

post {
  url: {{api_host}}/v1/authorize/resources
  body: json
  auth: inherit
}

body:json {
  {
    "name": "",
    "code": "",
    "max_scope": "",
    "min_scope": ""
  }
}

script:post-response {
  const pkg = require('./scripts/error-400-fields-missing');
  
  pkg.testMissingFields('name', 'code', 'max_scope', 'min_scope');
  
}

settings {
  encodeUrl: true
  timeout: 0
}
