meta {
  name: Resource Search - Create test data - Init
  type: http
  seq: 1
}

post {
  url: {{api_host}}/v1/authorize/resources
  body: json
  auth: inherit
}

body:json {
  {
    "name": "{{$randomColor}} {{$randomWord}} {{$timestamp}}",
    "code": "<Modified by Pre-request Script>",
    "description": "{{$randomLoremParagraphs}}",
    "max_scope": "domain",
    "min_scope": "private"
  }
}

script:pre-request {
  const body = req.getBody();
  body.name = bru.interpolate(body.name);
  body.code = body.name.toLowerCase().replace(/\s/g, "_");
  req.setBody(body);
}

script:post-response {
  const pkg = require('./scripts/common-test-response');
  
  const schema = {
    type: 'object',
    required: ['id'],
    properties: {
      id: {
        type: 'string',
        minLength: 1,
      },
      code: {
        type: 'string',
        minLength: 1,
      },
      description: {
        type: 'string',
        minLength: 1,
      },
      etag: {
          type: 'string',
          minLength: 1,
      },
      name: {
        type: 'string',
        minLength: 1,
      },
      max_scope: {
        type: 'string',
        minLength: 1,
      },
      min_scope: {
        type: 'string',
        minLength: 1,
      },
      owner_type: {
        type: 'string',
        minLength: 1,
      },
      created_at: {
        type: "string",
        minLength: 20, //"2026-03-23T06:53:01Z"
      },
      updated_at: {
        type: "string",
        minLength: 20, //"2026-03-23T06:53:01Z"
      },
    },
    additionalProperties: false,
  };
  
  pkg.initTestData(
    'Resource Search', schema,
    'Resource Search - Create test data - Loop 50',
  );
}

settings {
  encodeUrl: true
  timeout: 0
}
