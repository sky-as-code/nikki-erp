meta {
  name: Resource Search - No criteria, With paging - Success
  type: http
  seq: 2
}

get {
  url: {{api_host}}/v1/authorize/resources?page=1&size=5
  body: none
  auth: inherit
}

params:query {
  page: 1
  size: 5
}

script:post-response {
  const pkg = require('./scripts/search-success');
  
  pkg.testSearch(5, 1);
  
}

settings {
  encodeUrl: true
  timeout: 0
}
