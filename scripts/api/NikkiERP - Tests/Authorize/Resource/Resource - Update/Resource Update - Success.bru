meta {
  name: Resource Update - Success
  type: http
  seq: 1
}

patch {
  url: {{api_host}}/v1/authorize/resources/{{resource_id}}
  body: json
  auth: inherit
}

body:json {
  {
    "description": "{{$randomLoremParagraphs}}",
    "etag": "{{etag}}"
  }
}

script:post-response {
  const pkg = require('./scripts/update-success');
  
  pkg.testUpdate(1);
  
}

settings {
  encodeUrl: true
  timeout: 0
}
