meta {
  name: Entitlement Update - Client error (Not match etags)
  type: http
  seq: 4
}

patch {
  url: {{api_host}}/v1/authorize/entitlements/{{entitlement_id}}
  body: json
  auth: inherit
}

body:json {
  {
      "description": "description",
      "etag": "1752720685738865000"
  }
}

script:post-response {
  test("Status code is 400", function () {
      expect(res.getStatus()).to.equal(400);
  });
  
  test("Returns validation_error code", function () {
      const json = res.getBody();
      expect(json.code).to.eql("validation_error");
  });
  
  test("Returns etag conflict message", function () {
      const json = res.getBody();
      expect(json.details).to.have.property("etag", "etag mismatched");
  });
  
}

settings {
  encodeUrl: true
}
