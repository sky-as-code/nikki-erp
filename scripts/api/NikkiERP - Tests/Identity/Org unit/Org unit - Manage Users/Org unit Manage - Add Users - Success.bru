meta {
  name: Org unit Manage - Add Users - Success
  type: http
  seq: 1
}

post {
  url: {{api_host}}/v1/identity/orgunits/{{orgunit_id}}/manage-users
  body: json
  auth: inherit
}

body:json {
  {
    "add": ["<< Managed by script >>"]
  }
}

script:pre-request {
  const pkg = require('./scripts/common-test-response');
  const userIds = pkg.getTestDataIds('user_ids');
  const payload = req.getBody();
  
  payload.add = userIds.slice(0, userIds.length / 2);
  req.setBody(payload);
}

script:post-response {
  const pkg = require('./scripts/update-success');
  const { getTestDataIds } = require('./scripts/common-test-response');
  const userIds = getTestDataIds('user_ids');
  
  pkg.testUpdate(userIds.length / 2);
}

settings {
  encodeUrl: true
  timeout: 0
}
