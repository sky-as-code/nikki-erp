meta {
  name: Org unit Update - Unmatched etag - Validation errors
  type: http
  seq: 2
}

patch {
  url: {{api_host}}/v1/identity/orgunits/{{orgunit_id}}
  body: json
  auth: inherit
}

body:json {
  {
    "name": "{{$randomDepartment}} Updated",
    "etag": "old-etag"
  }
}

script:post-response {
  const pkg = require('./scripts/error-400-etag-unmatched');
  
  pkg.testUnmatchedEtag();
  
}

settings {
  encodeUrl: true
  timeout: 0
}
