meta {
  name: User Search - Create test data - Init
  type: http
  seq: 1
}

post {
  url: {{api_host}}/v1/identity/users
  body: json
  auth: inherit
}

body:json {
  {
      "display_name": "Tester Lead {{$randomFirstName}}",
      "email": "{{$randomEmail}}"
  }
}

script:pre-request {
  const body = req.getBody();
  console.log('User Search: Creating test user: ', bru.interpolate(body.display_name));
}

script:post-response {
  test("Status code is 201", function () {
    expect(res.getStatus()).to.equal(201);
  });
  
  const schema = {
    type: "object",
    properties: {
      items: {
        type: "array",
        items: {
          type: "object",
          required: ["id", "created_at", "display_name", "email", "etag", "is_archived", "status"],
          properties: {
            id: {
              type: "string",
              minLength: 1,
            },
            avatar_url: {
              type: "string",
              format: "uri",
            },
            created_at: {
              type: "string",
              minLength: 20, //"2026-03-23T06:53:01Z"
            },
            display_name: {
              type: "string",
              minLength: 1,
            },
            email: {
              type: "string",
              minLength: 1,
            },
            etag: {
              type: "string",
              minLength: 1,
            },
            is_archived: {
              type: "boolean",
            },
            is_owner: {
              type: "boolean",
            },
            status: {
              type: "string",
              minLength: 1,
              //enum: ["active", "locked", "archived"]
            },
            updated_at: {
              type: "string",
              minLength: 20, //"2026-03-23T06:53:01Z"
            }
          }
        }
      },
      total: {
        type: "integer",
        minimum: 0
      },
      page: {
        type: "integer",
        minimum: 0
      },
      size: {
        type: "integer",
        minimum: 1
      }
    },
    required: ["items", "total", "page", "size"]
  }
  bru.setVar("search_schema", schema);
  
  /*
   * Configure loop
   */
  const LOOP_COUNT = 100;
  bru.setVar("loop_count", LOOP_COUNT);
  
  console.log(`User Search: Creating ${LOOP_COUNT} test records`)
  bru.runner.setNextRequest('User Search - Create test data - Loop 100');
  
  
}

settings {
  encodeUrl: true
  timeout: 0
}
