meta {
  name: User Search - Invalid fields - Validation errors
  type: http
  seq: 13
}

get {
  url: {{api_host}}/v1/identity/users?page=-1&size=999999999999999999&graph={"if":["fake-field", "=", "Owner"]}
  body: none
  auth: inherit
}

params:query {
  page: -1
  size: 999999999999999999
  graph: {"if":["fake-field", "=", "Owner"]}
}

script:post-response {
  const pkg = require('./scripts/error-400-invalid-range');
  
  pkg.testInvalidNumberRange('page', 'size');
  
}

settings {
  encodeUrl: true
  timeout: 0
}
