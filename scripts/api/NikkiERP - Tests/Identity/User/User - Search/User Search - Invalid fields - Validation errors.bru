meta {
  name: User Search - Invalid fields - Validation errors
  type: http
  seq: 14
}

get {
  url: {{api_host}}/v1/identity/users?page=-1&size=999999999999999999&graph={"if":["fake-field", "=", "Owner"]}
  body: none
  auth: inherit
}

params:query {
  page: -1
  size: 999999999999999999
  graph: {"if":["fake-field", "=", "Owner"]}
}

script:pre-request {
  bru.deleteVar('search_schema')
}

script:post-response {
  const tv4 = require('tv4');
  
  const schema = {
      type: "array",
      minItems: 1,
      maxItems: 1,
      items: {
          type: "object",
          required: ["field", "key", "message", "type"],
          properties: {
              field: {
                  type: "string",
                  enum: ["fake-field"],
              },
              key: {
                  type: "string",
                  enum: ["common.err_unknown_schema_field"],
              },
              message: {
                  type: "string",
                  enum: ["field is not defined on this schema"],
              },
              type: {
                  type: "string",
                  enum: ["validation"],
              },
          },
          additionalProperties: false,
      },
      additionalItems: false
  };
  
  test("Status code is 400", function () {
      expect(res.getStatus()).to.equal(400);
  });
  
  test("Response matches expected JSON schema", function () {
    console.log({body: res.getBody()});
    const valid = tv4.validate(res.getBody(), schema);
    tv4.error && console.error(tv4.error);
    expect(tv4.error).not.to.exist;
    expect(valid).to.be.true;  
  });
  
}

settings {
  encodeUrl: true
  timeout: 0
}
