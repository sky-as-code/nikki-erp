meta {
  name: User Search - If root field - Success
  type: http
  seq: 6
}

get {
  url: {{api_host}}/v1/identity/users?graph={"if":["display_name", "*", "lead"]}
  body: none
  auth: inherit
}

params:query {
  graph: {"if":["display_name", "*", "lead"]}
}

script:post-response {
  const pkg = require('./scripts/search-success');
  
  pkg.testSearch(50);
  
}

settings {
  encodeUrl: true
  timeout: 0
}
