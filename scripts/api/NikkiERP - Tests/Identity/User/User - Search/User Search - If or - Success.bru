meta {
  name: User Search - If or - Success
  type: http
  seq: 7
}

get {
  url: {{api_host}}/v1/identity/users?graph={"or":[{"if":["display_name", "*", "Lead"]},{"if": ["email", "^", "ed"]}]}
  body: none
  auth: inherit
}

params:query {
  graph: {"or":[{"if":["display_name", "*", "Lead"]},{"if": ["email", "^", "ed"]}]}
}

script:post-response {
  const pkg = require('./scripts/search-success');
  
  pkg.testSearch(50);
  
}

settings {
  encodeUrl: true
  timeout: 0
}
