meta {
  name: User Search - If and - Success
  type: http
  seq: 8
}

get {
  url: {{api_host}}/v1/identity/users?graph={"and":[{"if":["display_name", "*", "tester"]},{"if": ["email", "$", ".com"]}]}
  body: none
  auth: inherit
}

params:query {
  graph: {"and":[{"if":["display_name", "*", "tester"]},{"if": ["email", "$", ".com"]}]}
}

script:post-response {
  const pkg = require('./scripts/search-success');
  
  pkg.testSearch(50);
  
}

settings {
  encodeUrl: true
  timeout: 0
}
