meta {
  name: User Search - If and or nested - Success
  type: http
  seq: 10
}

get {
  url: {{api_host}}/v1/identity/users?graph={"or":[{"if":["display_name", "*", "Lead"]},{"and":[{"if": ["status", "*", "o"]},{"if": ["status", "*", "w"]}]}]}
  body: none
  auth: inherit
}

params:query {
  graph: {"or":[{"if":["display_name", "*", "Lead"]},{"and":[{"if": ["status", "*", "o"]},{"if": ["status", "*", "w"]}]}]}
}

script:post-response {
  const pkg = require('./scripts/search-success');
  
  pkg.testSearch(50);
  
}

settings {
  encodeUrl: true
  timeout: 0
}
