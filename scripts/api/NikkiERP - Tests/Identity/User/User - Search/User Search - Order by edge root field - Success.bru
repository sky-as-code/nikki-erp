meta {
  name: User Search - Order by edge root field - Success
  type: http
  seq: 10
}

get {
  url: {{api_host}}/v1/identity/users?graph={"order": [["groups.name", "desc"]]}&columns=display_name&columns=groups.name
  body: none
  auth: inherit
}

params:query {
  graph: {"order": [["groups.name", "desc"]]}
  columns: display_name
  columns: groups.name
}

script:post-response {
  const pkg = require('./scripts/search-success');
  
  pkg.testSearch(50);
  
}

settings {
  encodeUrl: true
  timeout: 0
}
