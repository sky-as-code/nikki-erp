meta {
  name: User Search - If edge root field - Success
  type: http
  seq: 7
}

get {
  url: {{api_host}}/v1/identity/users?graph={"if": ["status", "!=", "active"]}
  body: none
  auth: inherit
}

params:query {
  graph: {"if": ["status", "!=", "active"]}
}

script:post-response {
  const pkg = require('./scripts/search-success');
  
  pkg.testSearch(50);
  
}

settings {
  encodeUrl: true
  timeout: 0
}
