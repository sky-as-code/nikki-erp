meta {
  name: User Search - No criteria, With paging - Success
  type: http
  seq: 4
}

get {
  url: {{api_host}}/v1/identity/users?page=2&size=7
  body: none
  auth: inherit
}

params:query {
  page: 2
  size: 7
}

script:post-response {
  const pkg = require('./scripts/search-success');
  
  pkg.testSearch(7, 2);
  
}

settings {
  encodeUrl: true
  timeout: 0
}
