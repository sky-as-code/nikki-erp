meta {
  name: User Get - Ignore readonly fields - Success
  type: http
  seq: 5
}

get {
  url: {{api_host}}/v1/identity/users/{{user_id}}
  body: none
  auth: inherit
}

script:post-response {
  
  const { testHttpResponse } = require('./scripts/common-test-response');
  
  const schema = {
      type: "object",
      required: ["id", "created_at", "display_name", "email", "etag", "is_archived", "status"],
      properties: {
          id: {
              type: "string",
              minLength: 1,
          },
          avatar_url: {
              type: "string",
              format: "uri",
          },
          created_at: {
              type: "string",
              minLength: 20, //"2026-03-23T06:53:01Z"
          },
          display_name: {
              type: "string",
              minLength: 1,
          },
          email: {
              type: "string",
              format: "email",
              minLength: 1,
          },
          etag: {
              type: "string",
              minLength: 1,
          },
          is_owner: {
              type: "boolean",
          },
          is_archived: {
              type: "boolean",
          },
          status: {
              type: "string",
              minLength: 1,
          },
          updated_at: {
              type: "string",
              minLength: 20, //"2026-03-23T06:53:01Z"
          }
      },
      additionalProperties: false
  };
  
  testHttpResponse(schema, 200);
  
  test('Readonly fields are ignored', function () {
    ignoredIsOwner = bru.getVar('ignoredIsOwner');
    ignoredIsArchived = bru.getVar('ignoredIsArchived');
    const {
      is_owner: actualIsOwner,
      is_archived: actualIsArchived,
    } = res.getBody();
  
    expect(ignoredIsOwner).not.equal(actualIsOwner);
    expect(ignoredIsArchived).not.equal(actualIsArchived);
  });
}

settings {
  encodeUrl: true
  timeout: 0
}
