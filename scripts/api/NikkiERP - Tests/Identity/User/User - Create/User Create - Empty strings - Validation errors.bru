meta {
  name: User Create - Empty strings - Validation errors
  type: http
  seq: 5
}

post {
  url: {{api_host}}/v1/identity/users
  body: json
  auth: inherit
}

body:json {
  {
      "display_name": "",
      "email": ""
  }
}

script:post-response {
  const pkg = require('./scripts/error-400-fields-missing');
  
  pkg.testMissingFields("display_name", "email");
  
}

settings {
  encodeUrl: true
  timeout: 0
}
