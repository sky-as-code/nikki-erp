meta {
  name: User Create - Empty strings - Validation errors
  type: http
  seq: 4
}

post {
  url: {{api_host}}/v1/identity/users
  body: json
  auth: inherit
}

body:json {
  {
      "display_name": "",
      "email": ""
  }
}

script:post-response {
  const pkg = require('./scripts/common-test-response');
  
  const schema = {
      type: "array",
      minItems: 2,
      maxItems: 2,
      items: {
          type: "object",
          required: ["field", "key", "message", "type"],
          properties: {
              field: {
                  type: "string",
                  enum: ["display_name", "email"],
              },
              key: {
                  type: "string",
                  enum: ["common.err_missing_required_field"],
              },
              message: {
                  type: "string",
                  enum: ["field is required"],
              },
              type: {
                  type: "string",
                  enum: ["validation"],
              },
              vars: {
                type: "object"
              }
          },
          additionalProperties: false,
      },
      additionalItems: false
  };
  
  pkg.testHttpResponse(schema, 400);
  
}

settings {
  encodeUrl: true
  timeout: 0
}
