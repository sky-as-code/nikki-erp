meta {
  name: User Exists - Invalid ID format - Validation errors
  type: http
  seq: 5
}

post {
  url: {{api_host}}/v1/identity/users/exists
  body: json
  auth: inherit
}

body:json {
  {
    "ids": ["invalid"]
  }
}

script:post-response {
  const pkg = require('./scripts/error-400-invalid-format');
  
  pkg.testInvalidFormat('ids');
  
}

settings {
  encodeUrl: true
  timeout: 0
}
