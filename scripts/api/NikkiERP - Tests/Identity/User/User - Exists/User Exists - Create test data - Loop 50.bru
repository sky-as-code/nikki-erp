meta {
  name: User Exists - Create test data - Loop 50
  type: http
  seq: 2
}

post {
  url: {{api_host}}/v1/identity/users
  body: json
  auth: inherit
}

body:json {
  {
      "display_name": "Tester {{$randomFirstName}} {{loop_count}}",
      "email": "{{loop_count}}-{{$randomEmail}}"
  }
}

script:pre-request {
  const body = req.getBody();
  console.log('User Exists Loop: Creating test user: ', bru.interpolate(body.displayName));
}

script:post-response {
  test("Status code is 201", function () {
    expect(res.getStatus()).to.equal(201);
  });
  
  
  const idArr = bru.getVar('user_ids').split(',');
  const { id } = res.getBody();
  if (id) {
    idArr.push(id);
    bru.setVar('user_ids', idArr.join(','));
  }
  
  
  let i = bru.getVar("loop_count");
  
  if (i > 0) {
      bru.setVar("loop_count", --i);
      console.log("Still loop: ", i)
      bru.runner.setNextRequest('User Exists - Create test data - Loop 50');
  } else {
      console.log("To test case")
      bru.deleteVar("loop_count")
      bru.runner.setNextRequest('User Exists - One - Success');
  }
  
}

settings {
  encodeUrl: true
  timeout: 0
}
