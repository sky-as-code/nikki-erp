meta {
  name: User Exists - Create test data - Init
  type: http
  seq: 1
}

post {
  url: {{api_host}}/v1/identity/users
  body: json
  auth: inherit
}

body:json {
  {
      "display_name": "Tester Lead {{$randomFirstName}}",
      "email": "{{$randomEmail}}"
  }
}

script:pre-request {
  const body = req.getBody();
  console.log('User Exists Init: Creating test user: ', bru.interpolate(body.display_name));
}

script:post-response {
  test("Status code is 201", function () {
    expect(res.getStatus()).to.equal(201);
  });
  
  /*
   * Configure loop
   */
  const LOOP_COUNT = 51;
  bru.setVar("loop_count", LOOP_COUNT);
  
  console.log(`User Exists: Creating ${LOOP_COUNT} test records`)
  bru.runner.setNextRequest('User Exists - Create test data - Loop 50');
  
  let idArr = bru.getVar('user_ids');
  if (!idArr) {
    idArr = [];
  } else {
    idArr = idArr.split(',');
  }
  
  const { id } = res.getBody();
  if (id) {
    idArr.push(id);
    bru.setVar('user_ids', idArr.join(','));
  }
  
}

settings {
  encodeUrl: true
  timeout: 0
}
