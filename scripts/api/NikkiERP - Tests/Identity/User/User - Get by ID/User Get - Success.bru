meta {
  name: User Get - Success
  type: http
  seq: 1
}

get {
  url: {{api_host}}/v1/identity/users/{{user_id}}
  body: none
  auth: inherit
}

script:post-response {
  const { testHttpResponse } = require('./scripts/common-test-response');
  
  const schema = {
      type: "object",
      required: ["id", "created_at", "display_name", "email", "etag", "is_archived", "status"],
      properties: {
          id: {
              type: "string",
              minLength: 1,
          },
          avatar_url: {
              type: "string",
              format: "uri",
          },
          created_at: {
              type: "string",
              minLength: 20, //"2026-03-23T06:53:01Z"
          },
          display_name: {
              type: "string",
              minLength: 1,
          },
          email: {
              type: "string",
              format: "email",
              minLength: 1,
          },
          etag: {
              type: "string",
              minLength: 1,
          },
          is_owner: {
              type: "boolean",
          },
          is_archived: {
              type: "boolean",
          },
          status: {
              type: "string",
              minLength: 1,
          },
          updated_at: {
              type: "string",
              minLength: 20, //"2026-03-23T06:53:01Z"
          },
          org_unit_id: {
            type: "string",
            minLength: 1,
          },
      },
      additionalProperties: false
  };
  
  testHttpResponse(schema, 200);
  
  const { etag } = res.getBody();
  etag && bru.setVar('etag', etag);
}

settings {
  encodeUrl: true
  timeout: 0
}
