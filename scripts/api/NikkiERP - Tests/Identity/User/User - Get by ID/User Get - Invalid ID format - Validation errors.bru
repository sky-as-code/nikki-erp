meta {
  name: User Get - Invalid ID format - Validation errors
  type: http
  seq: 7
}

get {
  url: {{api_host}}/v1/identity/users/not-valid-1234567890123
  body: none
  auth: inherit
}

script:post-response {
  const pkg = require('./scripts/error-400-invalid-format');
  
  pkg.testInvalidFormat('id');
  
}

settings {
  encodeUrl: true
  timeout: 0
}
