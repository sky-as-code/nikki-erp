meta {
  name: User Get - Non-exist column - Validation error
  type: http
  seq: 3
}

get {
  url: {{api_host}}/v1/identity/users/{{user_id}}?columns=display_name&columns=email&columns=non_exist
  body: none
  auth: inherit
}

params:query {
  columns: display_name
  columns: email
  columns: non_exist
}

script:post-response {
  const tv4 = require('tv4');
  
  const schema = {
    type: "array",
    minItems: 1,
    maxItems: 1,
    items: {
      type: "object",
      required: ["field", "key", "message", "type"],
      properties: {
        field: {
          type: "string",
          enum: ["non_exist"],
        },
        key: {
          type: "string",
          enum: ["common.err_unknown_schema_field"],
        },
        message: {
          type: "string",
          enum: ["field is not defined on this schema"],
        },
        type: {
          type: "string",
          enum: ["validation"],
        },
      },
      additionalProperties: false,
    },
    additionalItems: false
  };
  
  test("Status code is 400", function () {
      expect(res.getStatus()).to.equal(400);
  });
  
  test("Response matches expected JSON schema", function () {
    console.log({body: res.getBody()});
    const valid = tv4.validate(res.getBody(), schema);
    tv4.error && console.error(tv4.error);
    expect(tv4.error).not.to.exist;
    expect(valid).to.be.true;  
  });
  
}

settings {
  encodeUrl: true
  timeout: 0
}
