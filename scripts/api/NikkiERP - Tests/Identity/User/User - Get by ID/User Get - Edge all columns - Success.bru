meta {
  name: User Get - Edge all columns - Success
  type: http
  seq: 3
}

get {
  url: {{api_host}}/v1/identity/users/{{seed_user_id}}?columns=email&columns=groups
  body: none
  auth: inherit
}

params:query {
  columns: email
  columns: groups
}

script:post-response {
  
  const { testHttpResponse } = require('./scripts/common-test-response');
  
  const schema = {
    type: "object",
    required: ["id", "email", "groups"],
    properties: {
      id: {
        type: "string",
        minLength: 1,
      },
      email: {
        type: "string",
        format: "email",
        minLength: 1,
      },
      groups: {
        type: "array",
        minItems: 1,
        items: {
          type: "object",
          required: ['id', 'description', 'created_at', 'name', 'etag', 'is_archived'],
          properties: {
            id: {
              type: 'string',
              minLength: 1,
            },
            created_at: {
                type: "string",
                minLength: 20, //"2026-03-23T06:53:01Z"
            },
            name: {
                type: 'string',
                minLength: 1,
            },
            description: {
                type: 'string',
                minLength: 1,
            },
            etag: {
                type: 'string',
                minLength: 1,
            },
            is_archived: {
                type: "boolean",
            },
            updated_at: {
                type: "string",
                minLength: 20, //"2026-03-23T06:53:01Z"
            },
          },
          additionalProperties: false,
        },
      },
    },
    additionalProperties: false,
  };
  
  testHttpResponse(schema, 200);
  
}

settings {
  encodeUrl: true
  timeout: 0
}
