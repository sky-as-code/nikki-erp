meta {
  name: User Update - Duplicate email - Business errors
  type: http
  seq: 2
}

put {
  url: {{api_host}}/v1/identity/users/{{user_id}}
  body: json
  auth: inherit
}

body:json {
  {
      "email": "{{duplicate_email}}",
      "etag": "{{etag}}"
  }
}

script:post-response {
  const pkg = require('./scripts/error-400-duplicate-value');
  
  pkg.testDuplicateValues(['email']);
  
}

settings {
  encodeUrl: true
  timeout: 0
}
