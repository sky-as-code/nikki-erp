meta {
  name: User Update - Success
  type: http
  seq: 1
}

put {
  url: {{api_host}}/v1/identity/users/{{user_id}}
  body: json
  auth: inherit
}

body:json {
  {
      "avatar_url": "{{$randomUrl}}/{{$randomWord}}.jpg",
      "display_name": "{{$randomFullName}}",
      "email": "{{$randomNanoId}}-{{$randomEmail}}",
      "etag": "{{etag}}",
      "status": "invited"
  }
  
}

script:post-response {
  const pkg = require('./scripts/update-success');
  
  pkg.testUpdate(1);
  
  const { email } = req.getBody();
  email && bru.setVar('email', email);
  
}

settings {
  encodeUrl: true
  timeout: 0
}
