meta {
  name: User Update - Empty strings - Validation errors
  type: http
  seq: 3
}

patch {
  url: {{api_host}}/v1/identity/users/{{user_id}}
  body: json
  auth: inherit
}

body:json {
  {
      "avatar_url": "",
      "display_name": "",
      "email": "",
      "etag": ""
  }
}

script:post-response {
  const pkg = require('./scripts/error-400-fields-missing');
  
  pkg.testMissingFields('etag');
  
}

settings {
  encodeUrl: true
  timeout: 0
}
