meta {
  name: User Update - Invalid fields - Validation errors
  type: http
  seq: 3
}

patch {
  url: {{api_host}}/v1/identity/users/{{user_id}}
  body: json
  auth: inherit
}

body:json {
  {    "display_name": "too-longgggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggg",
      "email": "invalid@",
      "etag": "fake",
      "orgIds": [""]
  }
}

script:post-response {
  const pkg = require('./scripts/common-test-response');
  
  const schema = {
      type: "array",
      minItems: 3,
      maxItems: 3,
      items: {
          type: "object",
          required: ["field", "key", "message", "type"],
          properties: {
              field: {
                  type: "string",
                  enum: ["etag", "display_name", "email"],
              },
              key: {
                  type: "string",
                  enum: ["common.err_invalid_string_length", "common.err_invalid_email"],
              },
              message: {
                  type: "string",
                  enum: ["string length must be between {{.min}} and {{.max}}", "must be a valid email address"],
              },
              type: {
                  type: "string",
                  enum: ["validation"],
              },
              vars: {
                  type: "object",
                  properties: {
                    max: {
                      type: "integer",
                    },
                    min: {
                      type: "integer",
                    },
                  },
              },
          },
          additionalProperties: false,
      },
      additionalItems: false
  };
  
  pkg.testHttpResponse(schema, 400);
  
}

settings {
  encodeUrl: true
  timeout: 0
}
