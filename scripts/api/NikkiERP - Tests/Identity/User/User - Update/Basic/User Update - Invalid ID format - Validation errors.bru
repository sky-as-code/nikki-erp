meta {
  name: User Update - Invalid ID format - Validation errors
  type: http
  seq: 3
}

put {
  url: {{api_host}}/v1/identity/users/not-invalid-1234567890123
  body: json
  auth: inherit
}

body:json {
  {
    "etag": "{{etag}}"
  }
}

script:post-response {
  const pkg = require('./scripts/error-400-invalid-format');
  
  pkg.testInvalidFormat('id');
  
}

settings {
  encodeUrl: true
  timeout: 0
}
