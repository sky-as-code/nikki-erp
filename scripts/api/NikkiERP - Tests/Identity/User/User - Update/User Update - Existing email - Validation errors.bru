meta {
  name: User Update - Existing email - Validation errors
  type: http
  seq: 7
}

put {
  url: {{api_host}}/v1/identity/users/{{user_id}}
  body: json
  auth: inherit
}

body:json {
  {
      "email": "{{email}}",
      "etag": "{{etag}}"
  }
}

script:post-response {
  const tv4 = require('tv4');
  
  const schema = {
      type: "array",
      minItems: 1,
      maxItems: 1,
      items: {
          type: "object",
          required: ["field", "key", "message", "type"],
          properties: {
              field: {
                  type: "string",
                  enum: ["email"],
              },
              key: {
                  type: "string",
                  enum: ["common.err_unique_constraint_violated"],
              },
              message: {
                  type: "string",
                  enum: ["unique constraint violated {{.uniques}}"],
              },
              type: {
                  type: "string",
                  enum: ["business"],
              },
              vars: {
                  type: "object",
                  properties: {
                    uniques: {
                      type: "array",
                    },
                  },
              },
          },
          additionalProperties: false,
      },
      additionalItems: false
  };
  
  test("Status code is 400", function () {
      expect(res.getStatus()).to.equal(400);
  });
  
  test("Response matches expected JSON schema", function () {
    console.log({body: res.getBody()});
    const valid = tv4.validate(res.getBody(), schema);
    tv4.error && console.error(tv4.error);
    expect(tv4.error).not.to.exist;
    expect(valid).to.be.true;  
  });
  
}

settings {
  encodeUrl: true
  timeout: 0
}
