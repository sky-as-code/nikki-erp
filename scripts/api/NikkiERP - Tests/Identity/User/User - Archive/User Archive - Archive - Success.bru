meta {
  name: User Archive - Archive - Success
  type: http
  seq: 1
}

post {
  url: {{api_host}}/v1/identity/users/{{user_id}}/archived
  body: json
  auth: inherit
}

body:json {
  {
    "etag": "{{etag}}",
    "is_archived": true
  }
}

script:post-response {
  const { testUpdate } = require('./scripts/update-success');
  
  testUpdate(1);
  
}

settings {
  encodeUrl: true
  timeout: 0
}
