meta {
  name: User Archive - Empty etag - Validation errors
  type: http
  seq: 6
}

post {
  url: {{api_host}}/v1/identity/users/{{user_id}}/archived
  body: json
  auth: inherit
}

body:json {
  {
    "etag": "",
    "is_archived": true
  }
}

script:post-response {
  const pkg = require('./scripts/error-400-fields-missing');
  
  pkg.testMissingFields('etag');
  
}

settings {
  encodeUrl: true
  timeout: 0
}
