meta {
  name: User Update - Empty etag - Validation errors
  type: http
  seq: 6
}

post {
  url: {{api_host}}/v1/identity/users/{{user_id}}/archived
  body: json
  auth: inherit
}

body:json {
  {
    "etag": "",
    "is_archived": true
  }
}

script:post-response {
  const tv4 = require('tv4');
  
  const schema = {
      type: "array",
      minItems: 1,
      maxItems: 1,
      items: {
          type: "object",
          required: ["field", "key", "message", "type"],
          properties: {
              field: {
                  type: "string",
                  enum: ["etag"],
              },
              key: {
                  type: "string",
                  enum: ["common.err_invalid_length"],
              },
              message: {
                  type: "string",
                  enum: ["must have length between {{.min}} and {{.max}}"],
              },
              type: {
                  type: "string",
                  enum: ["validation"],
              },
              vars: {
                type: "object",
              }
          },
          additionalProperties: false,
      },
      additionalItems: false
  };
  
  test("Status code is 400", function () {
      expect(res.getStatus()).to.equal(400);
  });
  
  test("Response matches expected JSON schema", function () {
    console.log({body: res.getBody()});
    const valid = tv4.validate(res.getBody(), schema);
    tv4.error && console.error(tv4.error);
    expect(tv4.error).not.to.exist;
    expect(valid).to.be.true;  
  });
  
  
}

settings {
  encodeUrl: true
  timeout: 0
}
