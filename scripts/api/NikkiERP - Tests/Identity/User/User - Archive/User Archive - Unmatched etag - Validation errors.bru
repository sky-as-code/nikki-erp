meta {
  name: User Archive - Unmatched etag - Validation errors
  type: http
  seq: 4
}

post {
  url: {{api_host}}/v1/identity/users/{{user_id}}/archived
  body: json
  auth: inherit
}

body:json {
  {
    "etag": "___________________",
    "is_archived": true
  }
}

script:post-response {
  const pkg = require('./scripts/error-400-etag-unmatched');
  
  pkg.testUnmatchedEtag();
  
}

settings {
  encodeUrl: true
  timeout: 0
}
