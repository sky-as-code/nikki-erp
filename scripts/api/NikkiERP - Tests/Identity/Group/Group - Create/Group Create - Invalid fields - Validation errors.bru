meta {
  name: Group Create - Invalid fields - Validation errors
  type: http
  seq: 8
}

post {
  url: {{api_host}}/v1/identity/groups
  body: json
  auth: inherit
}

body:json {
  {
      "name": "too-longgggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggg",
    "owner_id": "not-valid-1234567890123"
  }
}

script:post-response {
  const pkg = require('./scripts/common-test-response');
  
  const schema = {
      type: "array",
      minItems: 2,
      maxItems: 2,
      items: {
          type: "object",
          required: ["field", "key", "message", "type"],
          properties: {
              field: {
                  type: "string",
                  enum: ["name", "owner_id"],
              },
              key: {
                  type: "string",
                  enum: ["common.err_invalid_string_length", "common.err_invalid_data_type"],
              },
              message: {
                  type: "string",
                  enum: ["string length must be between {{.min}} and {{.max}}", "invalid data type"],
              },
              type: {
                  type: "string",
                  enum: ["validation"],
              },
              vars: {
                  type: "object",
                  properties: {
                    max: {
                      type: "integer",
                    },
                    min: {
                      type: "integer",
                    },
                  },
              },
          },
          additionalProperties: false,
      },
      additionalItems: false
  };
  
  pkg.testHttpResponse(schema, 400);
  
}

settings {
  encodeUrl: true
  timeout: 0
}
