meta {
  name: Group Create - Empty strings - Validation errors
  type: http
  seq: 6
}

post {
  url: {{api_host}}/v1/identity/groups
  body: json
  auth: inherit
}

body:json {
  {
    "name": "",
    "description": "",
    "owner_id": ""
  }
}

script:post-response {
  const pkg = require('./scripts/error-400-fields-missing');
  
  pkg.testMissingFields("name", "owner_id");
  
}

settings {
  encodeUrl: true
  timeout: 0
}
