meta {
  name: Group Get - Ignore readonly fields - Success
  type: http
  seq: 5
}

get {
  url: {{api_host}}/v1/identity/groups/{{group_id}}
  body: none
  auth: inherit
}

script:post-response {
  
  const { testHttpResponse } = require('./scripts/common-test-response');
  
  const schema = {
      type: "object",
      required: ["id", "created_at", "description", "etag", "is_archived", "name"],
      properties: {
          id: {
              type: "string",
              minLength: 1,
          },
          owner_id: {
              type: "string",
              minLength: 1,
          },
          created_at: {
              type: "string",
              minLength: 20,
          },
          description: {
              type: "object",
          },
          etag: {
              type: "string",
              minLength: 1,
          },
          is_archived: {
              type: "boolean",
          },
          name: {
              type: "object",
          },
          updated_at: {
              type: "string",
              minLength: 20,
          }
      },
      additionalProperties: false
  };
  
  testHttpResponse(schema, 200);
  
  test('Readonly fields are ignored', function () {
    ignoredIsArchived = bru.getVar('ignoredIsArchived');
    const { is_archived: actualIsArchived } = res.getBody();
  
    expect(ignoredIsArchived).not.equal(actualIsArchived);
  });
}

settings {
  encodeUrl: true
  timeout: 0
}
