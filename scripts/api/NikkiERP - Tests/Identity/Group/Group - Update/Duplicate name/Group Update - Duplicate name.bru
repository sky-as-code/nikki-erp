meta {
  name: Group Update - Duplicate name
  type: http
  seq: 2
}

put {
  url: {{api_host}}/v1/identity/groups/{{group_id}}
  body: json
  auth: inherit
}

body:json {
  {
      "name": {{duplicate_name}},
      "etag": "{{etag}}"
  }
}

script:post-response {
  const pkg = require('./scripts/error-400-duplicate-value');
  
  pkg.testDuplicateValues(['name']);
  
}

settings {
  encodeUrl: true
  timeout: 0
}
