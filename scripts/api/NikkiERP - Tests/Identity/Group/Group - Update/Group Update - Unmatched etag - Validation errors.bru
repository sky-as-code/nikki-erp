meta {
  name: Group Update - Unmatched etag - Validation errors
  type: http
  seq: 3
}

put {
  url: {{api_host}}/v1/identity/groups/{{group_id}}
  body: json
  auth: inherit
}

body:json {
  {
      "etag": "___________________"
  }
}

script:post-response {
  const pkg = require('./scripts/error-400-etag-unmatched');
  
  pkg.testUnmatchedEtag();
  
}

settings {
  encodeUrl: true
  timeout: 0
}
