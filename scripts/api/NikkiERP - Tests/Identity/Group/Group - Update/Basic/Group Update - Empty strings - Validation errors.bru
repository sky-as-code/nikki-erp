meta {
  name: Group Update - Empty strings - Validation errors
  type: http
  seq: 1
}

patch {
  url: {{api_host}}/v1/identity/groups/{{group_id}}
  body: json
  auth: inherit
}

body:json {
  {
      "name": "",
      "description": "",
      "etag": ""
  }
}

script:post-response {
  const pkg = require('./scripts/error-400-fields-missing');
  
  pkg.testMissingFields('etag');
  
}

settings {
  encodeUrl: true
  timeout: 0
}
