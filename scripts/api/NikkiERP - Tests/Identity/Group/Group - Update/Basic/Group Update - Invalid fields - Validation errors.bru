meta {
  name: Group Update - Invalid fields - Validation errors
  type: http
  seq: 2
}

patch {
  url: {{api_host}}/v1/identity/groups/{{group_id}}
  body: json
  auth: inherit
}

body:json {
  {
      "name": {
        "en-US": "too-longgggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggg"
      },
      "etag": "fake"
  }
}

script:post-response {
  const pkg = require('./scripts/error-400-invalid-length');
  
  pkg.testInvalidStringLength('etag', 'name.en-US');
  
}

settings {
  encodeUrl: true
  timeout: 0
}
