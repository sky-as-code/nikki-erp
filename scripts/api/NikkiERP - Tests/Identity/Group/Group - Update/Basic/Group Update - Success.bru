meta {
  name: Group Update - Success
  type: http
  seq: 6
}

patch {
  url: {{api_host}}/v1/identity/groups/{{group_id}}
  body: json
  auth: inherit
}

body:json {
  {
    "name": {
      "en-US": "{{$randomJobArea}} {{$randomCatchPhraseAdjective}} {{$randomHexColor}}"
    },
    "description": {
      "en-US": "{{$randomLoremParagraphs}}"
    },
    "etag": "{{etag}}"
  }
}

script:post-response {
  const pkg = require('./scripts/update-success');
  
  pkg.testUpdate(1);
  
  const { name } = req.getBody();
  name && bru.setVar('name', name);
  
}

settings {
  encodeUrl: true
  timeout: 0
}
