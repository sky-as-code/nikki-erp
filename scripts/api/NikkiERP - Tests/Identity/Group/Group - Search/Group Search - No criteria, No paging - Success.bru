meta {
  name: Group Search - No criteria, No paging - Success
  type: http
  seq: 1
}

get {
  url: {{api_host}}/v1/identity/groups
  body: none
  auth: inherit
}

script:post-response {
  const pkg = require('./scripts/search-success');
  
  pkg.testSearch(50);
  
}

settings {
  encodeUrl: true
  timeout: 0
}
