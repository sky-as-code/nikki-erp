meta {
  name: Group Search - Order by root field - Success
  type: http
  seq: 9
}

get {
  url: {{api_host}}/v1/identity/groups?graph={"order": [["name", "desc"]]}&columns=name
  body: none
  auth: inherit
}

params:query {
  graph: {"order": [["name", "desc"]]}
  columns: name
}

script:post-response {
  const pkg = require('./scripts/search-success');
  
  pkg.testSearch(50);
  
}

settings {
  encodeUrl: true
  timeout: 0
}
