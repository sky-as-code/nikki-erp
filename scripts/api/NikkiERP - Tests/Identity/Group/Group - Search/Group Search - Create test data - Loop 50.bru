meta {
  name: Group Search - Create test data - Loop 50
  type: http
  seq: 2
}

post {
  url: {{api_host}}/v1/identity/groups
  body: json
  auth: inherit
}

body:json {
  {
      "name": "{{$randomJobArea}} {{$randomCatchPhraseAdjective}}",
      "description": "{{$randomLoremParagraphs}}"
  }
}

script:post-response {
  const pkg = require('./scripts/common-test-response');
  
  pkg.loopTestData(
    'Group Search - Create test data - Loop 50',
    'Group Search - No criteria, No paging - Success',
  );
  
}

settings {
  encodeUrl: true
  timeout: 0
}
