meta {
  name: Group Search - If root field - Success
  type: http
  seq: 4
}

get {
  url: {{api_host}}/v1/identity/groups?graph={"if":["name", "*", "brand"]}
  body: none
  auth: inherit
}

params:query {
  graph: {"if":["name", "*", "brand"]}
}

script:post-response {
  const pkg = require('./scripts/search-success');
  
  pkg.testSearch(50);
  
}

settings {
  encodeUrl: true
  timeout: 0
}
