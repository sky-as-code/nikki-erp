meta {
  name: Group Search - If and - Success
  type: http
  seq: 6
}

get {
  url: {{api_host}}/v1/identity/groups?graph={"and":[{"if":["name", "^", "quality"]},{"if": ["is_archived", "=", false]}]}
  body: none
  auth: inherit
}

params:query {
  graph: {"and":[{"if":["name", "^", "quality"]},{"if": ["is_archived", "=", false]}]}
}

script:post-response {
  const pkg = require('./scripts/search-success');
  
  pkg.testSearch(50);
  
}

settings {
  encodeUrl: true
  timeout: 0
}
