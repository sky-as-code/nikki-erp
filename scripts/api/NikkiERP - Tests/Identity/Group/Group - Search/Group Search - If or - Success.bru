meta {
  name: Group Search - If or - Success
  type: http
  seq: 7
}

get {
  url: {{api_host}}/v1/identity/groups?graph={"or":[{"if":["name", "*", "Manager"]},{"if": ["name", "^", "Quality"]}]}
  body: none
  auth: inherit
}

params:query {
  graph: {"or":[{"if":["name", "*", "Manager"]},{"if": ["name", "^", "Quality"]}]}
}

script:post-response {
  const pkg = require('./scripts/search-success');
  
  pkg.testSearch(50);
  
}

settings {
  encodeUrl: true
  timeout: 0
}
