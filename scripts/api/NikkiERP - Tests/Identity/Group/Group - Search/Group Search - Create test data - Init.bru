meta {
  name: Group Search - Create test data - Init
  type: http
  seq: 1
}

post {
  url: {{api_host}}/v1/identity/groups
  body: json
  auth: inherit
}

body:json {
  {
      "name": "{{$randomJobArea}} {{$randomCatchPhraseAdjective}}",
      "description": "{{$randomLoremParagraphs}}"
  }
}

script:post-response {
  const pkg = require('./scripts/common-test-response');
  
  const schema = {
    type: 'object',
    required: ['id', 'description', 'created_at', 'name', 'etag', 'is_archived'],
    properties: {
      id: {
        type: 'string',
        minLength: 1,
      },
      created_at: {
        type: "string",
        minLength: 20, //"2026-03-23T06:53:01Z"
      },
      name: {
        type: 'string',
        minLength: 1,
      },
      description: {
        type: 'string',
        minLength: 1,
      },
      etag: {
        type: 'string',
        minLength: 1,
      },
      is_archived: {
        type: "boolean",
      },
      updated_at: {
        type: "string",
        minLength: 20, //"2026-03-23T06:53:01Z"
      },
    },
    additionalProperties: false,
  };
  
  pkg.initTestData(
    'Group Search', schema,
    'Group Search - Create test data - Loop 50',
  );
}

settings {
  encodeUrl: true
  timeout: 0
}
