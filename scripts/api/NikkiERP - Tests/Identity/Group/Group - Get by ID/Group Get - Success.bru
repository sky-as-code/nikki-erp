meta {
  name: Group Get - Success
  type: http
  seq: 1
}

get {
  url: {{api_host}}/v1/identity/groups/{{group_id}}
  body: none
  auth: inherit
}

script:post-response {
  const { testHttpResponse } = require('./scripts/common-test-response');
  
  const schema = {
      type: 'object',
      required: ['id', 'description', 'created_at', 'name', 'etag', 'is_archived'],
      properties: {
          id: {
              type: 'string',
              minLength: 1,
          },
          created_at: {
              type: "string",
              minLength: 20, //"2026-03-23T06:53:01Z"
          },
          name: {
              type: 'string',
              minLength: 1,
          },
          description: {
              type: 'string',
              minLength: 1,
          },
          etag: {
              type: 'string',
              minLength: 1,
          },
          is_archived: {
              type: "boolean",
          },
          updated_at: {
              type: "string",
              minLength: 20, //"2026-03-23T06:53:01Z"
          },
      },
      additionalProperties: false
  };
  
  testHttpResponse(schema, 200);
  
}

settings {
  encodeUrl: true
  timeout: 0
}
