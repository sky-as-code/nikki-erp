meta {
  name: Group - Add duplicate Users - Success
  type: http
  seq: 2
}

post {
  url: {{api_host}}/v1/identity/groups/{{group_id}}/manage-users
  body: json
  auth: inherit
}

body:json {
  {
      "add": ["<< Managed by script >>"]
  }
}

script:pre-request {
  const pkg = require('./scripts/common-test-response');
  const groupUserIds = pkg.getTestDataIds('user_ids');
  
  const payload = req.getBody();
  
  // Add 50% new users to group
  payload.add = groupUserIds.slice(0, groupUserIds.length/2);
  
  req.setBody(payload);
  
}

script:post-response {
  const pkg = require('./scripts/update-success');
  
  pkg.testUpdate(0);
  
}

settings {
  encodeUrl: true
  timeout: 0
}
