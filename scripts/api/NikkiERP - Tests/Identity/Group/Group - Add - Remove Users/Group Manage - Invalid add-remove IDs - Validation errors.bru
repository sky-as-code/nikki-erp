meta {
  name: Group - Invalid add/remove IDs - Validation errors
  type: http
  seq: 8
}

post {
  url: {{api_host}}/v1/identity/groups/{{group_id}}/manage-users
  body: json
  auth: inherit
}

body:json {
  {
      "add": ["11113ZBF68C3DRN0371PER5BRC", "01"],
      "remove": ["22223ZBF68C3DRN0371PER5BRC", "33333ZBF68C3DRN0371PER5BRC", ""]
  }
}

script:post-response {
  const pkg = require('./scripts/error-400-invalid-format');
  
  pkg.testInvalidFormat('add', 'remove');
  
}

settings {
