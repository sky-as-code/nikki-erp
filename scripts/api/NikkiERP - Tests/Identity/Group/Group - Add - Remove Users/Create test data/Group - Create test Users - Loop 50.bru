meta {
  name: Group - Create test Users - Loop 50
  type: http
  seq: 1
}

post {
  url: {{api_host}}/v1/identity/users
  body: json
  auth: inherit
}

body:json {
  {
      "display_name": "{{$randomJobDescriptor}} {{$randomFirstName}} {{$randomHexColor}}",
      "email": "{{$randomNanoId}}-{{$randomEmail}}"
  }
}

script:post-response {
  const pkg = require('./scripts/common-test-response');
  
  pkg.loopTestDataWithIds(
    'Group - Create test Users - Loop 50',
    'Group - Add Users - Success',
    'user_ids',
  );
  
}

settings {
  encodeUrl: true
  timeout: 0
}
