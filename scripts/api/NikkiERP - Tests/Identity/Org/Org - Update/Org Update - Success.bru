meta {
  name: Org Update - Success
  type: http
  seq: 1
}

put {
  url: {{api_host}}/v1/identity/organizations/{{org_id}}
  body: json
  auth: inherit
}

body:json {
  {
    "display_name": "{{$randomCompanyName}} Updated",
    "legal_name": "{{$randomCompanyName}} LLC",
    "etag": "{{etag}}"
  }
}

script:post-response {
  const pkg = require('./scripts/update-success');
  
  pkg.testUpdate(1);
  
}

settings {
  encodeUrl: true
  timeout: 0
}
