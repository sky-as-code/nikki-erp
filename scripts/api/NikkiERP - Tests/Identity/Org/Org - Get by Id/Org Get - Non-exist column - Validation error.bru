meta {
  name: Org Get - Non-exist column - Validation error
  type: http
  seq: 2
}

get {
  url: {{api_host}}/v1/identity/organizations/{{org_id}}?columns=display_name&columns=bla_bla_field
  body: none
  auth: inherit
}

params:query {
  columns: display_name
  columns: bla_bla_field
}

script:post-response {
  const pkg = require('./scripts/error-400-nonexist-fields');
  
  pkg.testNonExistFields('bla_bla_field');
  
}

settings {
  encodeUrl: true
  timeout: 0
}
