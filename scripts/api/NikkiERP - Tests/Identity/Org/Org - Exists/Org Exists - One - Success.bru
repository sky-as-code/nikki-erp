meta {
  name: Org Exists - One - Success
  type: http
  seq: 1
}

post {
  url: {{api_host}}/v1/identity/organizations/exists
  body: json
  auth: inherit
}

body:json {
  {
    "ids": ["{{org_id}}"]
  }
}

script:post-response {
  const pkg = require('./scripts/exists-success');
  
  pkg.testExists(1, 0);
  
}

settings {
  encodeUrl: true
  timeout: 0
}
