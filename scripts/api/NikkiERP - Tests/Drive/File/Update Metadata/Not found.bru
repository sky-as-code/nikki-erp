meta {
  name: Not found
  type: http
  seq: 2
}

patch {
  url: {{api_host}}/v1/drive/files/:driveFileId
  body: json
  auth: inherit
}

params:path {
  driveFileId: 01KJRSPN1337QBNS6MBG89PZZS
}

headers {
  Authorization: Bearer {{accessToken}}
}

body:json {
  {
    "etag": "{{driveFileEtag}}",
    "name": "abc",
    "visibility": "",
    "status": ""
  }
}

tests {
  test("Status is 400", function() {
      expect(res.getStatus()).to.equal(400);
  });
  
  test("Should has error", function() {
      expect(res.getBody()?.details?.driveFileId).to.equal("drive file not found");
  });
}

settings {
  encodeUrl: true
  timeout: 0
}
