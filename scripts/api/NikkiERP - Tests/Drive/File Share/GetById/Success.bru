meta {
  name: Success
  type: http
  seq: 1
}

get {
  url: {{api_host}}/v1/drive/files/:driveFileId/shares/:driveFileShareId
  body: none
  auth: inherit
}

params:path {
  driveFileShareId: {{LatestDriveFileShareId}}
  driveFileId: {{DriveFileId}}
}

script:post-response {
  bru.setVar("DriveFileShareEtag",res.getBody().etag)
}

settings {
  encodeUrl: true
  timeout: 0
}
