meta {
  name: Invalid Permission
  type: http
  seq: 2
}

put {
  url: {{api_host}}/v1/drive/files/:driveFileId/shares/:driveFileShareId
  body: json
  auth: inherit
}

params:path {
  driveFileId: {{DriveFileId}}
  driveFileShareId: {{LatestDriveFileShareId}}
}

body:json {
  {
    "etag": "{{DriveFileShareEtag}}",
    "permission": "edit-trash123"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
