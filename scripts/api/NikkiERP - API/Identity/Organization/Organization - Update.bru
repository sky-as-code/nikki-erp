meta {
  name: Organization - Update
  type: http
  seq: 2
}

put {
  url: {{api_host}}/v1/identity/organizations/{{org_id}}
  body: json
  auth: inherit
}

body:json {
  {
    "display_name": "{{$randomCompanyName}} Updated",
    "legal_name": "{{$randomCompanyName}} LLC",
    "etag": "{{etag}}"
  }
}

script:post-response {
  const payload = res.getBody();
  const { etag } = payload;
  etag && bru.setVar('etag', etag);
}

settings {
  encodeUrl: true
  timeout: 0
}
