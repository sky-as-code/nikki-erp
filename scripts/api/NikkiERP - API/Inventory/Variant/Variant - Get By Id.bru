meta {
  name: Variant - Get By Id
  type: http
  seq: 3
}

get {
  url: {{api_host}}/v1/{{org_id}}/inventory/products/{{product_id}}/variants/{{variant_id}}
  body: none
  auth: inherit
}

script:post-response {
  const { etag } = res.getBody();
  etag && bru.setVar('etag', etag);
}

vars:pre-request {
  variant_id: 01KK11JNA5NZY5RCPZXG2B15EK
}

settings {
  encodeUrl: true
  timeout: 0
}
