      sku: "JACKET-LEATHER-L",
      barcode: "8938501234576",
      price: 1299000,
      status: "active",
      attributes: {
        color: { "vi-VN": "Đen", "en-US": "Black" },
        size: 20,
        material: { "vi-VN": "Da", "en-US": "Leather" }
      }
    },
    {
      name: { vi: "Áo khoác jeans xanh M", en: "Blue Denim Jacket size M" },
      sku: "JACKET-DENIM-M",
      barcode: "8938501234577",
      price: 799000,
      status: "active",
      attributes: {
        color: { "vi-VN": "Xanh", "en-US": "Blue" },
        size: 19,
        material: { "vi-VN": "Jeans", "en-US": "Denim" }
      }
    },
    {
      name: { vi: "Giày thể thao trắng 42", en: "White Sneakers size 42" },
      sku: "SHOES-WHITE-42",
      barcode: "8938501234578",
      price: 899000,
      status: "active",
      attributes: {
        color: { "vi-VN": "Trắng", "en-US": "White" },
        size: 42
      }
    },
    {
      name: { vi: "Giày thể thao đen 43", en: "Black Sneakers size 43" },
      sku: "SHOES-BLACK-43",
      barcode: "8938501234579",
      price: 899000,
      status: "active",
      attributes: {
        color: { "vi-VN": "Đen", "en-US": "Black" },
        size: 43
      }
    },
    {
      name: { vi: "Mũ lưỡi trai đỏ", en: "Red Baseball Cap" },
      sku: "CAP-RED-OS",
      barcode: "8938501234580",
      price: 129000,
      status: "active",
      attributes: {
        color: { "vi-VN": "Đỏ", "en-US": "Red" }
      }
    },
    {
      name: { vi: "Mũ lưỡi trai đen", en: "Black Baseball Cap" },
      sku: "CAP-BLACK-OS",
      barcode: "8938501234581",
      price: 129000,
      status: "discontinued",
      attributes: {
        color: { "vi-VN": "Đen", "en-US": "Black" }
      }
    }
  ];
  
  // Danh sách trạng thái
  const statuses = ['draft', 'active', 'discontinued'];
  
  // Random chọn một variant và trạng thái
  const randomVariant = variants[Math.floor(Math.random() * variants.length)];
  const randomStatus = statuses[Math.floor(Math.random() * statuses.length)];
  
  // Set variables với giá trị mặc định
  bru.setVar('variant_name_vi', randomVariant.name.vi || "Áo thun màu đỏ M");
  bru.setVar('variant_name_en', randomVariant.name.en || "Red T-shirt size M");
  bru.setVar('variant_sku', randomVariant.sku || "TSHIRT-RED-M");
  bru.setVar('variant_barcode', randomVariant.barcode || "8938501234567");
  bru.setVar('variant_price', randomVariant.price || 199000);
  bru.setVar('variant_status', randomStatus || "active");
  bru.setVar('variant_attributes', JSON.stringify(randomVariant.attributes || {}));
}

script:post-response {
  const { etag } = res.getBody();
  etag && bru.setVar('etag', etag);
}

vars:pre-request {
  variant_id: 01KJ87WNPCBRAP77BFR08WBN13
}

settings {
  encodeUrl: true
  timeout: 0
}
