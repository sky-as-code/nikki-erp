      sku: "JEANS-LTBLUE-30",
      barcode: "8938501234570",
      price: 459000,
      status: "active",
      attributes: {
        color: { "vi-VN": "Xanh nhạt", "en-US": "Light Blue" },
        size: 30
      }
    },
    {
      name: { vi: "Quần jean đen 32", en: "Black Jeans size 32" },
      sku: "JEANS-BLACK-32",
      barcode: "8938501234571",
      price: 479000,
      status: "active",
      attributes: {
        color: { "vi-VN": "Đen", "en-US": "Black" },
        size: 32
      }
    },
    {
      name: { vi: "Áo sơ mi trắng M", en: "White Shirt size M" },
      sku: "SHIRT-WHITE-M",
      barcode: "8938501234572",
      price: 349000,
      status: "active",
      attributes: {
        color: { "vi-VN": "Trắng", "en-US": "White" },
        size: 19
      }
    },
    {
      name: { vi: "Áo sơ mi xanh navy L", en: "Navy Shirt size L" },
      sku: "SHIRT-NAVY-L",
      barcode: "8938501234573",
      price: 369000,
      status: "active",
      attributes: {
        color: { "vi-VN": "Xanh navy", "en-US": "Navy" },
        size: 20
      }
    },
    {
      name: { vi: "Váy đen S", en: "Black Dress size S" },
      sku: "DRESS-BLACK-S",
      barcode: "8938501234574",
      price: 549000,
      status: "active",
      attributes: {
        color: { "vi-VN": "Đen", "en-US": "Black" },
        size: 18
      }
    },
    {
      name: { vi: "Váy hoa M", en: "Floral Dress size M" },
      sku: "DRESS-FLORAL-M",
      barcode: "8938501234575",
      price: 569000,
      status: "active",
      attributes: {
        color: { "vi-VN": "Hoa", "en-US": "Floral" },
        size: 19
      }
    },
    {
