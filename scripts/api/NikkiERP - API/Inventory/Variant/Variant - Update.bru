meta {
  name: Variant - Update
  type: http
  seq: 2
}

put {
  url: {{api_host}}/v1/{{org_id}}/inventory/products/{{product_id}}/variants/{{variant_id}}
  body: json
  auth: inherit
}

body:json {
  {
    "name": {
      "vi-VN" : "{{variant_name_vi}}",
      "en-US" : "{{variant_name_en}}"
    },
    "sku": "{{variant_sku}}",
    "barcode": "{{variant_barcode}}",
    "proposedPrice": {{variant_price}},
    "status": "{{variant_status}}",
    "attributes": {{variant_attributes}},
    "etag": "{{etag}}"
  }
}

vars:pre-request {
  org_id: 01JWNY20G23KD4RV5VWYABQYHD
  variant_id: 01KJ87WNPCBRAP77BFR08WBN13
  variant_name_vi: Áo thun màu đỏ M
  variant_name_en: Red T-shirt size M
  variant_sku: TSHIRT-RED-M
  variant_barcode: 8938501234567
  variant_price: 199000
  variant_status: active
  variant_attributes: {"color":{"vi-VN":"Đỏ","en-US":"Red"},"size":19}
}

script:pre-request {
  // Danh sách variant với các biến thể khác nhau
  const variants = [
    {
