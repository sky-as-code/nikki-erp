      price: 199000,
      status: "active",
      attributes: {
        color: { "vi-VN": "Đỏ", "en-US": "Red" },
        size: 19
      }
    },
    {
      name: { vi: "Áo thun màu xanh L", en: "Blue T-shirt size L" },
      sku: "TSHIRT-BLUE-L",
      barcode: "8938501234568",
