meta {
  name: Attribute - Search
  type: http
  seq: 4
}

get {
  url: {{api_host}}/v1/{{org_id}}/inventory/products/{{product_id}}/attributes?countValues=true&countVariants=true
  body: none
  auth: inherit
}

params:query {
  countValues: true
  countVariants: true
}

settings {
  encodeUrl: true
  timeout: 0
}
