meta {
  name: Attribute Group - Create
  type: http
  seq: 1
}

post {
  url: {{api_host}}/v1/{{org_id}}/inventory/products/{{product_id}}/attribute-groups
  body: json
  auth: inherit
}

body:json {
  {
    "name": {
       "en": "Machinery parts",
       "vi": "Bộ phận máy móc"
    }
  }
}

script:post-response {
  const { id, etag } = res.getBody();
  id && bru.setVar('attribute_group_id', id);
  etag && bru.setVar('etag', etag);
}

settings {
  encodeUrl: true
  timeout: 0
}
