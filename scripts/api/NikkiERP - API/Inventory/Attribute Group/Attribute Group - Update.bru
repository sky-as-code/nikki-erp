meta {
  name: Attribute Group - Update
  type: http
  seq: 2
}

put {
  url: {{api_host}}/v1/{{org_id}}/inventory/products/{{product_id}}/attribute-groups/{{attribute_group_id}}
  body: json
  auth: inherit
}

body:json {
  {
    "name": {
       "en": "Pharmaceuticals",
       "vi": "Dược phẩm"
    },
    "etag": "1772097910571845000"
  }
}

script:post-response {
  const { etag } = res.getBody();
  etag && bru.setVar('etag', etag);
}

settings {
  encodeUrl: true
  timeout: 0
}
