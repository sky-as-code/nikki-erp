meta {
  name: Unit Category - Get By Id
  type: http
  seq: 3
}

get {
  url: {{api_host}}/v1/{{org_id}}/inventory/unit-categories/{{unit_category_id}}
  body: none
  auth: inherit
}

script:post-response {
  const { etag } = res.getBody();
  etag && bru.setVar('etag', etag);
}

vars:pre-request {
  unit_category_id: 01KJCP7ZGKB8M31Q3ZA52V8PD6
}

settings {
  encodeUrl: true
  timeout: 0
}
