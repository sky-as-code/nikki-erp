meta {
  name: Unit Category - Create
  type: http
  seq: 1
}

post {
  url: {{api_host}}/v1/{{org_id}}/inventory/unit-categories
  body: json
  auth: inherit
}

body:json {
  {
    "name": {
       "en": "Length",
       "vi": "Chiều dài"
    }
  }
}

script:post-response {
  const { id, etag } = res.getBody();
  id && bru.setVar('unit_category_id', id);
  etag && bru.setVar('etag', etag);
}

settings {
  encodeUrl: true
  timeout: 0
}
