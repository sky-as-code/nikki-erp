meta {
  name: Product Category - Get By Id
  type: http
  seq: 3
}

get {
  url: {{api_host}}/v1/{{org_id}}/inventory/products-categories/{{product_category_id}}
  body: none
  auth: inherit
}

vars:pre-request {
  org_id: 01JWNY20G23KD4RV5VWYABQYHD
}

script:post-response {
  const { etag } = res.getBody();
  etag && bru.setVar('etag', etag);
}

settings {
  encodeUrl: true
  timeout: 0
}
