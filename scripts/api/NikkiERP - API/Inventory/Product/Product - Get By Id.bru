meta {
  name: Product - Get By Id
  type: http
  seq: 3
}

get {
  url: {{api_host}}/v1/{{org_id}}/inventory/products/{{product_id}}?withVariants=true&withAttributes=true
  body: none
  auth: inherit
}

params:query {
  withVariants: true
  withAttributes: true
}

settings {
  encodeUrl: true
  timeout: 0
}
