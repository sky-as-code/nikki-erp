meta {
  name: Product - Update
  type: http
  seq: 2
}

put {
  url: {{api_host}}/v1/{{org_id}}/inventory/products/{{product_id}}
  body: json
  auth: inherit
}

body:json {
  {
    "name": {
      "en": "orange",
      "vi": "cam"
    },
    "defaultsVariantId": "01KJ48F6ZXVHKSS0JP0KGYK454",
    "status": "active",
    "unitId": "{{unit_id}}",
    "etag": "1771922873745825800"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
