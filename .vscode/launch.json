{
	// Use IntelliSense to learn about possible attributes.
	// Hover to view descriptions of existing attributes.
	// For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Main Program",
			"type": "go",
			"request": "launch",
			"mode": "debug",
			"program": "${workspaceRoot}",
			"env": {
				"APP_ENV": "local",
				"WORKING_DIR": "${workspaceRoot}",
				"GENERAL_LOG_LEVEL": "debug",
			}
		},
		{
			"name": "Migration",
			"type": "go",
			"request": "launch",
			"mode": "debug",
			"program": "${workspaceRoot}",
			"buildFlags": "-tags=staticmods",
			"args": [
				"-createsql",
				"-dialect=postgres",
				"-module=${input:module}"
			]
		}
	],
	"inputs": [
		{
			"id": "module",
			"type": "promptString",
			"description": "Module name for migration"
		}
	]
}
